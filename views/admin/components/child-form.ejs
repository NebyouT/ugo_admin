<!-- Reusable Child Form Component -->
<div class="child-form-fields">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Full Name *</label>
            <input type="text" class="form-control child-full-name" required>
        </div>
        <div class="col-md-3">
            <label class="form-label">Date of Birth</label>
            <input type="date" class="form-control child-dob">
        </div>
        <div class="col-md-3">
            <label class="form-label">Gender</label>
            <select class="form-select child-gender">
                <option value="">Select</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">School</label>
            <input type="text" class="form-control child-school">
        </div>
        <div class="col-md-6">
            <label class="form-label">Grade</label>
            <input type="text" class="form-control child-grade" placeholder="e.g., Grade 5">
        </div>
        <div class="col-12">
            <label class="form-label">Pickup Address *</label>
            <input type="text" class="form-control child-pickup-address" required>
        </div>
        <div class="col-md-6">
            <label class="form-label">Latitude (optional)</label>
            <input type="number" step="0.000001" class="form-control child-lat">
        </div>
        <div class="col-md-6">
            <label class="form-label">Longitude (optional)</label>
            <input type="number" step="0.000001" class="form-control child-lng">
        </div>
        <div class="col-12"><hr><h6 class="mb-3">Emergency Contact</h6></div>
        <div class="col-md-4">
            <label class="form-label">Contact Name</label>
            <input type="text" class="form-control child-emergency-name">
        </div>
        <div class="col-md-4">
            <label class="form-label">Contact Phone</label>
            <input type="tel" class="form-control child-emergency-phone">
        </div>
        <div class="col-md-4">
            <label class="form-label">Relationship</label>
            <input type="text" class="form-control child-emergency-rel" placeholder="e.g., Mother">
        </div>
        <div class="col-12">
            <label class="form-label">Medical Notes</label>
            <textarea class="form-control child-medical" rows="2" placeholder="Any allergies, conditions, or special needs..."></textarea>
        </div>
    </div>
</div>

<script>
// Helper function to get child data from form
function getChildFormData(container) {
    return {
        full_name: container.querySelector('.child-full-name').value,
        date_of_birth: container.querySelector('.child-dob').value || null,
        gender: container.querySelector('.child-gender').value || null,
        school_id: container.querySelector('.child-school').value || null,
        grade: container.querySelector('.child-grade').value || null,
        pickup_location: {
            address: container.querySelector('.child-pickup-address').value,
            lat: parseFloat(container.querySelector('.child-lat').value) || null,
            lng: parseFloat(container.querySelector('.child-lng').value) || null
        },
        emergency_contact: {
            name: container.querySelector('.child-emergency-name').value || null,
            phone: container.querySelector('.child-emergency-phone').value || null,
            relationship: container.querySelector('.child-emergency-rel').value || null
        },
        medical_notes: container.querySelector('.child-medical').value || null
    };
}

// Helper function to populate child form
function populateChildForm(container, childData) {
    container.querySelector('.child-full-name').value = childData.full_name || '';
    container.querySelector('.child-dob').value = childData.date_of_birth ? childData.date_of_birth.split('T')[0] : '';
    container.querySelector('.child-gender').value = childData.gender || '';
    container.querySelector('.child-school').value = childData.school?.name || '';
    container.querySelector('.child-grade').value = childData.grade || '';
    container.querySelector('.child-pickup-address').value = childData.pickup_location?.address || '';
    container.querySelector('.child-lat').value = childData.pickup_location?.lat || '';
    container.querySelector('.child-lng').value = childData.pickup_location?.lng || '';
    container.querySelector('.child-emergency-name').value = childData.emergency_contact?.name || '';
    container.querySelector('.child-emergency-phone').value = childData.emergency_contact?.phone || '';
    container.querySelector('.child-emergency-rel').value = childData.emergency_contact?.relationship || '';
    container.querySelector('.child-medical').value = childData.medical_notes || '';
}
</script>
