<style>
.sidebar {
    min-height: 100vh;
    background: #1a1d29;
    color: white;
    position: fixed;
    left: 0;
    top: 0;
    width: 260px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}

.sidebar-brand {
    padding: 1.5rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}

.sidebar-brand .brand-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
}

.sidebar-brand h4 {
    margin: 0;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.5px;
}

.sidebar-brand .version {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.35);
    margin-top: 2px;
}

.sidebar-nav {
    flex: 1;
    padding: 0.75rem 0;
}

.nav-section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255,255,255,0.3);
    padding: 1.25rem 1.5rem 0.5rem;
    font-weight: 600;
}

.nav-divider {
    border-top: 1px solid rgba(255,255,255,0.06);
    margin: 0.5rem 1.25rem;
}

.sidebar-nav .nav-item {
    margin: 1px 0;
}

.sidebar-nav .nav-link {
    color: rgba(255,255,255,0.55);
    padding: 0.6rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.875rem;
    border-left: 3px solid transparent;
}

.sidebar-nav .nav-link:hover {
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.04);
}

.sidebar-nav .nav-link.active {
    color: #fff;
    background: rgba(102,126,234,0.12);
    border-left-color: #667eea;
}

.sidebar-nav .nav-link i {
    width: 20px;
    text-align: center;
    font-size: 0.95rem;
}

.sidebar-nav .nav-link .badge {
    margin-left: auto;
    font-size: 0.65rem;
    padding: 0.2em 0.55em;
    font-weight: 500;
}

.sidebar-user {
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.sidebar-user .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    flex-shrink: 0;
}

.sidebar-user .user-info {
    flex: 1;
    min-width: 0;
}

.sidebar-user .user-info .name {
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.sidebar-user .user-info .role {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    text-transform: capitalize;
}

.sidebar-user .logout-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.35);
    padding: 0.4rem;
    cursor: pointer;
    transition: color 0.2s;
    font-size: 0.9rem;
}

.sidebar-user .logout-btn:hover {
    color: #e74c3c;
}

@media (max-width: 768px) {
    .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
    }
    .sidebar.show {
        transform: translateX(0);
    }
}
</style>

<%
const cp = typeof currentPath !== 'undefined' ? currentPath : '';
const isActive = (path) => cp === path || cp === path + '/';
const isActiveGroup = (prefix) => cp.startsWith(prefix);
%>

<div class="sidebar" id="sidebar">
    <!-- Brand -->
    <div class="sidebar-brand">
        <div class="brand-icon"><i class="fas fa-bus"></i></div>
        <div>
            <h4>UGO Admin</h4>
            <div class="version">v2.0.0</div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
        <!-- Overview -->
        <div class="nav-section-label">Overview</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link <%= isActive('/') || isActive('') ? 'active' : '' %>" href="/admin">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
            </li>
        </ul>

        <div class="nav-divider"></div>

        <!-- User Management -->
        <div class="nav-section-label">User Management</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link <%= isActive('/users') ? 'active' : '' %>" href="/admin/users">
                    <i class="fas fa-users"></i> All Users
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= isActive('/parents') ? 'active' : '' %>" href="/admin/parents">
                    <i class="fas fa-user-friends"></i> Parents
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= isActive('/drivers') ? 'active' : '' %>" href="/admin/drivers">
                    <i class="fas fa-id-card"></i> Drivers
                </a>
            </li>
        </ul>

        <div class="nav-divider"></div>

        <!-- Developer -->
        <div class="nav-section-label">Developer</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link <%= isActive('/api-docs') ? 'active' : '' %>" href="/admin/api-docs">
                    <i class="fas fa-book"></i> API Documentation
                </a>
            </li>
        </ul>
    </nav>

    <!-- User Footer -->
    <div class="sidebar-user">
        <div class="user-avatar">
            <%= user.firstName ? user.firstName.charAt(0) : 'A' %><%= user.lastName ? user.lastName.charAt(0) : 'U' %>
        </div>
        <div class="user-info">
            <div class="name"><%= user.firstName %> <%= user.lastName %></div>
            <div class="role"><%= user.role || 'Admin' %></div>
        </div>
        <button class="logout-btn" onclick="logout()" title="Logout">
            <i class="fas fa-sign-out-alt"></i>
        </button>
    </div>
</div>

<script>
function logout() {
    if (confirm('Are you sure you want to logout?')) {
        // Clear cookie by making a POST to logout and also clear it client-side
        document.cookie = 'adminAuth=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT;';
        localStorage.removeItem('currentUser');
        window.location.href = '/admin/login';
    }
}

function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('show');
}
</script>
