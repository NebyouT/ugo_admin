<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --card-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
            margin-left: 250px;
        }

        .main-content {
            padding: 2rem;
            min-height: 100vh;
        }

        .page-header {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--card-shadow);
        }

        .drivers-card {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            box-shadow: var(--card-shadow);
        }

        .driver-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }

        .status-badge {
            font-size: 0.8rem;
            padding: 0.25rem 0.5rem;
        }

        .verification-badge {
            font-size: 0.8rem;
            padding: 0.25rem 0.5rem;
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .stats-card {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: var(--card-shadow);
            text-align: center;
        }

        .stats-number {
            font-size: 2rem;
            font-weight: bold;
            color: var(--primary-color);
        }

        .filter-section {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: var(--card-shadow);
        }

        .online-indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 0.5rem;
        }

        .online-dot {
            background-color: #28a745;
        }

        .offline-dot {
            background-color: #6c757d;
        }

        .busy-dot {
            background-color: #ffc107;
        }

        .rating-stars {
            color: #ffc107;
        }

        @media (max-width: 768px) {
            body {
                margin-left: 0;
            }
            
            .main-content {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle" onclick="toggleSidebar()">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar Component -->
    <%- include('../../components/sidebar', { user: user, currentPath: currentPath }) %>

    <div class="main-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-2">Driver Management</h1>
                    <p class="text-muted mb-0">Manage drivers, verification, and performance</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary me-2" onclick="refreshDrivers()">
                        <i class="fas fa-sync-alt me-2"></i>Refresh
                    </button>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDriverModal">
                        <i class="fas fa-plus me-2"></i>Add Driver
                    </button>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="totalDrivers">-</div>
                    <div class="text-muted">Total Drivers</div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="onlineDrivers">-</div>
                    <div class="text-muted">Online Now</div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="verifiedDrivers">-</div>
                    <div class="text-muted">Verified</div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="averageRating">-</div>
                    <div class="text-muted">Avg Rating</div>
                </div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="searchInput" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchInput" placeholder="Search drivers...">
                </div>
                <div class="col-md-2">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="verificationFilter" class="form-label">Verification</label>
                    <select class="form-select" id="verificationFilter">
                        <option value="">All Status</option>
                        <option value="verified">Verified</option>
                        <option value="pending">Pending</option>
                        <option value="rejected">Rejected</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="onlineFilter" class="form-label">Online Status</label>
                    <select class="form-select" id="onlineFilter">
                        <option value="">All</option>
                        <option value="online">Online</option>
                        <option value="offline">Offline</option>
                        <option value="busy">Busy</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-grid">
                        <button class="btn btn-outline-primary" onclick="applyFilters()">
                            <i class="fas fa-filter me-2"></i>Apply Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Drivers Table -->
        <div class="drivers-card">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Driver</th>
                            <th>Contact</th>
                            <th>License</th>
                            <th>Online Status</th>
                            <th>Verification</th>
                            <th>Rating</th>
                            <th>Trips</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="driversTableBody">
                        <!-- Drivers will be loaded here -->
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            <div class="pagination-container">
                <div class="text-muted" id="paginationInfo">
                    Showing 0 of 0 drivers
                </div>
                <nav id="paginationNav">
                    <!-- Pagination will be loaded here -->
                </nav>
            </div>
        </div>
    </div>

    <!-- Add Driver Modal -->
    <div class="modal fade" id="addDriverModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Driver</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addDriverForm">
                        <div class="row g-3">
                            <!-- Basic Information -->
                            <div class="col-12">
                                <h6>Basic Information</h6>
                            </div>
                            <div class="col-md-3">
                                <label for="firstName" class="form-label">First Name *</label>
                                <input type="text" class="form-control" id="firstName" name="firstName" required>
                            </div>
                            <div class="col-md-3">
                                <label for="lastName" class="form-label">Last Name *</label>
                                <input type="text" class="form-control" id="lastName" name="lastName" required>
                            </div>
                            <div class="col-md-3">
                                <label for="email" class="form-label">Email *</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                            <div class="col-md-3">
                                <label for="phone" class="form-label">Phone *</label>
                                <input type="tel" class="form-control" id="phone" name="phone" required>
                            </div>
                            
                            <!-- Driver Information -->
                            <div class="col-12">
                                <h6>Driver Information</h6>
                            </div>
                            <div class="col-md-4">
                                <label for="licenseNumber" class="form-label">License Number *</label>
                                <input type="text" class="form-control" id="licenseNumber" name="licenseNumber" required>
                            </div>
                            <div class="col-md-4">
                                <label for="licenseExpiry" class="form-label">License Expiry *</label>
                                <input type="date" class="form-control" id="licenseExpiry" name="licenseExpiry" required>
                            </div>
                            <div class="col-md-4">
                                <label for="serviceArea" class="form-label">Service Area</label>
                                <input type="text" class="form-control" id="serviceArea" name="serviceArea" placeholder="e.g., Downtown, Airport">
                            </div>
                            
                            <!-- Services -->
                            <div class="col-12">
                                <h6>Services</h6>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="rideService" name="services" value="ride" checked>
                                    <label class="form-check-label" for="rideService">
                                        Ride Service
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="parcelService" name="services" value="parcel">
                                    <label class="form-check-label" for="parcelService">
                                        Parcel Service
                                    </label>
                                </div>
                            </div>
                            
                            <!-- Address -->
                            <div class="col-12">
                                <h6>Address Information</h6>
                            </div>
                            <div class="col-md-3">
                                <label for="street" class="form-label">Street</label>
                                <input type="text" class="form-control" id="street" name="street">
                            </div>
                            <div class="col-md-3">
                                <label for="city" class="form-label">City</label>
                                <input type="text" class="form-control" id="city" name="city">
                            </div>
                            <div class="col-md-3">
                                <label for="state" class="form-label">State</label>
                                <input type="text" class="form-control" id="state" name="state">
                            </div>
                            <div class="col-md-3">
                                <label for="zipCode" class="form-label">Zip Code</label>
                                <input type="text" class="form-control" id="zipCode" name="zipCode">
                            </div>
                            
                            <!-- Emergency Contact -->
                            <div class="col-12">
                                <h6>Emergency Contact</h6>
                            </div>
                            <div class="col-md-4">
                                <label for="emergencyName" class="form-label">Contact Name</label>
                                <input type="text" class="form-control" id="emergencyName" name="emergencyName">
                            </div>
                            <div class="col-md-4">
                                <label for="emergencyPhone" class="form-label">Contact Phone</label>
                                <input type="tel" class="form-control" id="emergencyPhone" name="emergencyPhone">
                            </div>
                            <div class="col-md-4">
                                <label for="emergencyRelationship" class="form-label">Relationship</label>
                                <input type="text" class="form-control" id="emergencyRelationship" name="emergencyRelationship" placeholder="e.g., Spouse, Parent">
                            </div>
                            
                            <!-- Account -->
                            <div class="col-12">
                                <h6>Account Information</h6>
                            </div>
                            <div class="col-md-6">
                                <label for="password" class="form-label">Password *</label>
                                <input type="password" class="form-control" id="password" name="password" required>
                            </div>
                            <div class="col-md-6">
                                <label for="confirmPassword" class="form-label">Confirm Password *</label>
                                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveDriver()">Save Driver</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Container -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1050;">
        <div id="alertContainer"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentUser = null;
        let drivers = [];
        let currentPage = 1;
        let totalDrivers = 0;
        let totalPages = 0;

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            initializePage();
        });

        // Check authentication and load data
        async function initializePage() {
            try {
                await checkAuthStatus();
                await loadDrivers();
                await loadDriverStats();
                setupEventListeners();
            } catch (error) {
                console.error('Failed to initialize page:', error);
                if (error.message.includes('Authentication')) {
                    window.location.href = '/admin/login';
                }
            }
        }

        // Check authentication status
        async function checkAuthStatus() {
            try {
                const response = await fetch('/admin/auth/check');
                const result = await response.json();
                
                if (!result.success || !result.data.user) {
                    throw new Error('Authentication failed');
                }
                
                currentUser = result.data.user;
            } catch (error) {
                console.error('Auth check failed:', error);
                window.location.href = '/admin/login';
                throw error;
            }
        }

        // Load drivers from API
        async function loadDrivers(page = 1, filters = {}) {
            try {
                const params = new URLSearchParams({
                    page: page.toString(),
                    limit: '10',
                    userType: 'driver',
                    ...filters
                });
                
                const response = await fetch(`/api/users/drivers?${params}`);
                const result = await response.json();
                
                if (result.success) {
                    drivers = result.data.drivers || [];
                    currentPage = result.data.pagination.current;
                    totalPages = result.data.pagination.pages;
                    totalDrivers = result.data.pagination.total;
                    
                    renderDriversTable();
                    updatePagination();
                } else {
                    throw new Error(result.message || 'Failed to load drivers');
                }
            } catch (error) {
                console.error('Load drivers error:', error);
                showAlert('Failed to load drivers. Please try again.', 'danger');
            }
        }

        // Load driver statistics
        async function loadDriverStats() {
            try {
                const response = await fetch('/api/users/stats');
                const result = await response.json();
                
                if (result.success) {
                    const stats = result.data.driverStats || {};
                    document.getElementById('totalDrivers').textContent = stats.totalDrivers || 0;
                    document.getElementById('onlineDrivers').textContent = stats.onlineDrivers || 0;
                    document.getElementById('verifiedDrivers').textContent = stats.verifiedDrivers || 0;
                    document.getElementById('averageRating').textContent = (stats.averageRating || 0).toFixed(1);
                }
            } catch (error) {
                console.error('Load stats error:', error);
                // Set default values
                document.getElementById('totalDrivers').textContent = '0';
                document.getElementById('onlineDrivers').textContent = '0';
                document.getElementById('verifiedDrivers').textContent = '0';
                document.getElementById('averageRating').textContent = '0.0';
            }
        }

        // Render drivers table
        function renderDriversTable() {
            const tbody = document.getElementById('driversTableBody');
            tbody.innerHTML = '';

            if (drivers.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="fas fa-id-card fa-2x mb-2"></i>
                            <div>No drivers found</div>
                        </td>
                    </tr>
                `;
                return;
            }

            drivers.forEach(driver => {
                const row = createDriverRow(driver);
                tbody.appendChild(row);
            });
        }

        // Create driver table row
        function createDriverRow(driver) {
            const tr = document.createElement('tr');
            const driverDetail = driver.driverDetail || {};
            
            tr.innerHTML = `
                <td>
                    <div class="d-flex align-items-center">
                        <img src="${driver.profileImage || `https://ui-avatars.com/api/?name=${driver.firstName}+${driver.lastName}&background=random`}" 
                             alt="${driver.firstName} ${driver.lastName}" class="driver-avatar me-3">
                        <div>
                            <div class="fw-semibold">${driver.firstName} ${driver.lastName}</div>
                            <div class="text-muted small">
                                <span class="online-indicator ${getOnlineStatusClass(driverDetail.availabilityStatus)}"></span>
                                ${driverDetail.availabilityStatus || 'unknown'}
                            </div>
                        </div>
                    </div>
                </td>
                <td>
                    <div class="small">
                        <div><i class="fas fa-envelope me-1"></i>${driver.email}</div>
                        <div><i class="fas fa-phone me-1"></i>${driver.phone}</div>
                    </div>
                </td>
                <td>
                    <div class="small">
                        <div><strong>${driver.driverInfo?.licenseNumber || 'N/A'}</strong></div>
                        <div class="text-muted">Expires: ${driver.driverInfo?.licenseExpiry ? new Date(driver.driverInfo.licenseExpiry).toLocaleDateString() : 'N/A'}</div>
                    </div>
                </td>
                <td>
                    <span class="badge bg-${getOnlineStatusColor(driverDetail.availabilityStatus)} status-badge">
                        ${driverDetail.isOnline ? 'Online' : 'Offline'}
                    </span>
                </td>
                <td>
                    <span class="badge bg-${getVerificationColor(driver.driverInfo?.isVerified)} verification-badge">
                        ${driver.driverInfo?.isVerified ? 'Verified' : 'Pending'}
                    </span>
                </td>
                <td>
                    <div class="rating-stars">
                        ${generateRatingStars(driverDetail.averageRating || 0)}
                        <small class="text-muted">(${driverDetail.totalRatings || 0})</small>
                    </div>
                </td>
                <td>
                    <div class="small">
                        <div><strong>${driverDetail.rideCount || 0}</strong> rides</div>
                        <div><strong>${driverDetail.parcelCount || 0}</strong> parcels</div>
                    </div>
                </td>
                <td>
                    <div class="action-buttons">
                        <button class="btn btn-sm btn-outline-primary" onclick="viewDriver('${driver._id}')">
                            <i class="fas fa-eye"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" onclick="editDriver('${driver._id}')">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-${driver.isActive ? 'warning' : 'success'}" 
                                onclick="toggleDriverStatus('${driver._id}')">
                            <i class="fas fa-${driver.isActive ? 'ban' : 'check'}"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDriver('${driver._id}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </td>
            `;
            return tr;
        }

        // Get online status class
        function getOnlineStatusClass(status) {
            const classes = {
                'available': 'online-dot',
                'busy': 'busy-dot',
                'unavailable': 'offline-dot',
                'off_duty': 'offline-dot'
            };
            return classes[status] || 'offline-dot';
        }

        // Get online status color
        function getOnlineStatusColor(status) {
            const colors = {
                'available': 'success',
                'busy': 'warning',
                'unavailable': 'secondary',
                'off_duty': 'secondary'
            };
            return colors[status] || 'secondary';
        }

        // Get verification color
        function getVerificationColor(isVerified) {
            return isVerified ? 'success' : 'warning';
        }

        // Generate rating stars
        function generateRatingStars(rating) {
            const fullStars = Math.floor(rating);
            const halfStar = rating % 1 >= 0.5 ? 1 : 0;
            const emptyStars = 5 - fullStars - halfStar;
            
            let stars = '';
            for (let i = 0; i < fullStars; i++) {
                stars += '<i class="fas fa-star"></i>';
            }
            if (halfStar) {
                stars += '<i class="fas fa-star-half-alt"></i>';
            }
            for (let i = 0; i < emptyStars; i++) {
                stars += '<i class="far fa-star"></i>';
            }
            
            return stars;
        }

        // Update pagination
        function updatePagination() {
            const paginationInfo = document.getElementById('paginationInfo');
            const paginationNav = document.getElementById('paginationNav');
            
            paginationInfo.textContent = `Showing ${drivers.length} of ${totalDrivers} drivers`;
            
            if (totalPages <= 1) {
                paginationNav.innerHTML = '';
                return;
            }

            let paginationHTML = '<ul class="pagination pagination-sm">';
            
            // Previous button
            paginationHTML += `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="loadDrivers(${currentPage - 1}); return false;">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
            `;

            // Page numbers
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    paginationHTML += `
                        <li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="#" onclick="loadDrivers(${i}); return false;">${i}</a>
                        </li>
                    `;
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    paginationHTML += '<li class="page-item disabled"><a class="page-link">...</a></li>';
                }
            }

            // Next button
            paginationHTML += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="loadDrivers(${currentPage + 1}); return false;">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            `;

            paginationHTML += '</ul>';
            paginationNav.innerHTML = paginationHTML;
        }

        // Setup event listeners
        function setupEventListeners() {
            // Search input
            document.getElementById('searchInput').addEventListener('keyup', function(e) {
                if (e.key === 'Enter') {
                    applyFilters();
                }
            });
        }

        // Apply filters
        function applyFilters() {
            const filters = {
                search: document.getElementById('searchInput').value,
                status: document.getElementById('statusFilter').value,
                verificationStatus: document.getElementById('verificationFilter').value,
                onlineStatus: document.getElementById('onlineFilter').value
            };

            loadDrivers(1, filters);
        }

        // Refresh drivers
        async function refreshDrivers() {
            await loadDrivers(currentPage);
            await loadDriverStats();
            showAlert('Data refreshed successfully', 'success');
        }

        // Save driver (create)
        async function saveDriver() {
            try {
                const formData = new FormData(document.getElementById('addDriverForm'));
                const driverData = Object.fromEntries(formData);

                // Validate required fields
                if (!driverData.firstName || !driverData.lastName || !driverData.email || !driverData.password || !driverData.licenseNumber) {
                    showAlert('Please fill in all required fields', 'danger');
                    return;
                }

                // Password confirmation
                if (driverData.password !== driverData.confirmPassword) {
                    showAlert('Passwords do not match', 'danger');
                    return;
                }

                // Email validation
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRegex.test(driverData.email)) {
                    showAlert('Please enter a valid email address', 'danger');
                    return;
                }

                // Set user type to driver
                driverData.userType = 'driver';

                // Process services
                const services = [];
                if (driverData.services) {
                    if (Array.isArray(driverData.services)) {
                        services.push(...driverData.services);
                    } else {
                        services.push(driverData.services);
                    }
                }
                driverData.driverInfo = {
                    licenseNumber: driverData.licenseNumber,
                    licenseExpiry: driverData.licenseExpiry,
                    serviceArea: driverData.serviceArea,
                    services: services
                };

                // Build address object
                if (driverData.street || driverData.city || driverData.state || driverData.zipCode) {
                    driverData.address = {
                        street: driverData.street,
                        city: driverData.city,
                        state: driverData.state,
                        zipCode: driverData.zipCode,
                        country: 'USA'
                    };
                }

                // Emergency contact
                if (driverData.emergencyName || driverData.emergencyPhone) {
                    driverData.emergencyContact = {
                        name: driverData.emergencyName,
                        phone: driverData.emergencyPhone,
                        relationship: driverData.emergencyRelationship
                    };
                }

                // Remove temporary fields
                delete driverData.licenseNumber;
                delete driverData.licenseExpiry;
                delete driverData.serviceArea;
                delete driverData.services;
                delete driverData.street;
                delete driverData.city;
                delete driverData.state;
                delete driverData.zipCode;
                delete driverData.emergencyName;
                delete driverData.emergencyPhone;
                delete driverData.emergencyRelationship;
                delete driverData.confirmPassword;

                const response = await fetch('/api/users', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(driverData)
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('Driver created successfully!', 'success');
                    bootstrap.Modal.getInstance(document.getElementById('addDriverModal')).hide();
                    document.getElementById('addDriverForm').reset();
                    await loadDrivers();
                    await loadDriverStats();
                } else {
                    showAlert(result.message || 'Failed to create driver', 'danger');
                }
            } catch (error) {
                console.error('Save driver error:', error);
                showAlert('Failed to save driver. Please try again.', 'danger');
            }
        }

        // View driver details
        async function viewDriver(driverId) {
            try {
                const response = await fetch(`/api/users/${driverId}`);
                const result = await response.json();
                
                if (result.success) {
                    const driver = result.data.user;
                    // Create a detailed view modal
                    const modalHTML = `
                        <div class="modal fade" id="viewDriverModal" tabindex="-1">
                            <div class="modal-dialog modal-xl">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Driver Details</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <h6>Basic Information</h6>
                                                <p><strong>Name:</strong> ${driver.firstName} ${driver.lastName}</p>
                                                <p><strong>Email:</strong> ${driver.email}</p>
                                                <p><strong>Phone:</strong> ${driver.phone}</p>
                                                <p><strong>Status:</strong> ${driver.isActive ? 'Active' : 'Inactive'}</p>
                                                <p><strong>Loyalty Points:</strong> ${driver.loyaltyPoints || 0}</p>
                                            </div>
                                            <div class="col-md-6">
                                                <h6>Driver Information</h6>
                                                <p><strong>License Number:</strong> ${driver.driverInfo?.licenseNumber || 'N/A'}</p>
                                                <p><strong>License Expiry:</strong> ${driver.driverInfo?.licenseExpiry ? new Date(driver.driverInfo.licenseExpiry).toLocaleDateString() : 'N/A'}</p>
                                                <p><strong>Service Area:</strong> ${driver.driverInfo?.serviceArea || 'N/A'}</p>
                                                <p><strong>Verification:</strong> ${driver.driverInfo?.isVerified ? 'Verified' : 'Pending'}</p>
                                                <p><strong>Services:</strong> ${driver.driverInfo?.services?.join(', ') || 'N/A'}</p>
                                            </div>
                                        </div>
                                        ${driver.driverDetail ? `
                                            <div class="row mt-3">
                                                <div class="col-md-6">
                                                    <h6>Performance</h6>
                                                    <p><strong>Total Trips:</strong> ${driver.driverDetail.rideCount || 0}</p>
                                                    <p><strong>Parcel Deliveries:</strong> ${driver.driverDetail.parcelCount || 0}</p>
                                                    <p><strong>Average Rating:</strong> ${driver.driverDetail.averageRating || 0}</p>
                                                    <p><strong>Total Ratings:</strong> ${driver.driverDetail.totalRatings || 0}</p>
                                                    <p><strong>Total Earnings:</strong> $${driver.driverDetail.totalEarnings || 0}</p>
                                                </div>
                                                <div class="col-md-6">
                                                    <h6>Time Tracking</h6>
                                                    <p><strong>Online Time:</strong> ${driver.driverDetail.onlineTime || 0} minutes</p>
                                                    <p><strong>Driving Time:</strong> ${driver.driverDetail.onDrivingTime || 0} minutes</p>
                                                    <p><strong>Idle Time:</strong> ${driver.driverDetail.idleTime || 0} minutes</p>
                                                    <p><strong>Availability:</strong> ${driver.driverDetail.availabilityStatus || 'N/A'}</p>
                                                    <p><strong>Online Status:</strong> ${driver.driverDetail.isOnline ? 'Online' : 'Offline'}</p>
                                                </div>
                                            </div>
                                        ` : ''}
                                        ${driver.address ? `
                                            <div class="row mt-3">
                                                <div class="col-12">
                                                    <h6>Address Information</h6>
                                                    <p>${driver.address.street || ''}, ${driver.address.city || ''}, ${driver.address.state || ''} ${driver.address.zipCode || ''}, ${driver.address.country || ''}</p>
                                                </div>
                                            </div>
                                        ` : ''}
                                        ${driver.emergencyContact ? `
                                            <div class="row mt-3">
                                                <div class="col-12">
                                                    <h6>Emergency Contact</h6>
                                                    <p><strong>Name:</strong> ${driver.emergencyContact.name || 'N/A'}</p>
                                                    <p><strong>Phone:</strong> ${driver.emergencyContact.phone || 'N/A'}</p>
                                                    <p><strong>Relationship:</strong> ${driver.emergencyContact.relationship || 'N/A'}</p>
                                                </div>
                                            </div>
                                        ` : ''}
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    
                    // Remove existing modal if any
                    const existingModal = document.getElementById('viewDriverModal');
                    if (existingModal) {
                        existingModal.remove();
                    }
                    
                    // Add new modal and show it
                    document.body.insertAdjacentHTML('beforeend', modalHTML);
                    const modal = new bootstrap.Modal(document.getElementById('viewDriverModal'));
                    modal.show();
                } else {
                    showAlert(result.message || 'Failed to load driver details', 'danger');
                }
            } catch (error) {
                console.error('View driver error:', error);
                showAlert('Failed to load driver details', 'danger');
            }
        }

        // Edit driver
        function editDriver(driverId) {
            showAlert('Edit functionality coming soon!', 'info');
        }

        // Toggle driver status
        async function toggleDriverStatus(driverId) {
            try {
                const response = await fetch(`/api/users/${driverId}/toggle-status`, {
                    method: 'PATCH'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showAlert(result.message, 'success');
                    await loadDrivers();
                    await loadDriverStats();
                } else {
                    showAlert(result.message || 'Failed to toggle driver status', 'danger');
                }
            } catch (error) {
                console.error('Toggle status error:', error);
                showAlert('Failed to toggle driver status', 'danger');
            }
        }

        // Delete driver
        async function deleteDriver(driverId) {
            if (!confirm('Are you sure you want to delete this driver? This action cannot be undone.')) {
                return;
            }

            try {
                const response = await fetch(`/api/users/${driverId}`, {
                    method: 'DELETE'
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showAlert('Driver deleted successfully', 'success');
                    await loadDrivers();
                    await loadDriverStats();
                } else {
                    showAlert(result.message || 'Failed to delete driver', 'danger');
                }
            } catch (error) {
                console.error('Delete driver error:', error);
                showAlert('Failed to delete driver', 'danger');
            }
        }

        // Show alert message
        function showAlert(message, type = 'info') {
            const alertContainer = document.getElementById('alertContainer');
            const alertId = 'alert-' + Date.now();
            
            const alertHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert" id="${alertId}">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'danger' ? 'exclamation-triangle' : 'info-circle'} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            alertContainer.insertAdjacentHTML('beforeend', alertHTML);
            
            // Auto-dismiss after 5 seconds
            setTimeout(() => {
                const alert = document.getElementById(alertId);
                if (alert) {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }
            }, 5000);
        }

        // Periodic auth check (every 5 minutes)
        setInterval(checkAuthStatus, 5 * 60 * 1000);
    </script>
</body>
</html>
