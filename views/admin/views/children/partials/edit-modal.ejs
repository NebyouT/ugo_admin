<div class="modal fade" id="editChildModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Edit Child</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editChildForm">
                    <input type="hidden" id="editChildId">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name *</label>
                            <input type="text" class="form-control" id="editChildName" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date of Birth</label>
                            <input type="date" class="form-control" id="editChildDOB">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Gender</label>
                            <select class="form-select" id="editChildGender">
                                <option value="">Select</option>
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">School</label>
                            <input type="text" class="form-control" id="editChildSchool">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Grade</label>
                            <input type="text" class="form-control" id="editChildGrade" placeholder="e.g., Grade 5">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Pickup Address *</label>
                            <input type="text" class="form-control" id="editChildPickupAddress" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Latitude</label>
                            <input type="number" step="0.000001" class="form-control" id="editChildLat">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Longitude</label>
                            <input type="number" step="0.000001" class="form-control" id="editChildLng">
                        </div>
                        <div class="col-12"><hr><h6>Emergency Contact</h6></div>
                        <div class="col-md-4">
                            <label class="form-label">Contact Name</label>
                            <input type="text" class="form-control" id="editChildEmergencyName">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Contact Phone</label>
                            <input type="tel" class="form-control" id="editChildEmergencyPhone">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Relationship</label>
                            <input type="text" class="form-control" id="editChildEmergencyRel" placeholder="e.g., Mother">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Medical Notes</label>
                            <textarea class="form-control" id="editChildMedical" rows="2"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveChildEdit()"><i class="fas fa-save me-1"></i>Save Changes</button>
            </div>
        </div>
    </div>
</div>

<script>
async function saveChildEdit() {
    const form = document.getElementById('editChildForm');
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }

    const childId = document.getElementById('editChildId').value;
    const data = {
        full_name: document.getElementById('editChildName').value,
        date_of_birth: document.getElementById('editChildDOB').value || null,
        gender: document.getElementById('editChildGender').value || null,
        grade: document.getElementById('editChildGrade').value || null,
        pickup_location: {
            address: document.getElementById('editChildPickupAddress').value,
            lat: parseFloat(document.getElementById('editChildLat').value) || null,
            lng: parseFloat(document.getElementById('editChildLng').value) || null
        },
        emergency_contact: {
            name: document.getElementById('editChildEmergencyName').value || null,
            phone: document.getElementById('editChildEmergencyPhone').value || null,
            relationship: document.getElementById('editChildEmergencyRel').value || null
        },
        medical_notes: document.getElementById('editChildMedical').value || null
    };

    try {
        const res = await fetch(`/api/children/${childId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(data)
        });

        const result = await res.json();
        if (result.success) {
            showToast('Child updated successfully');
            bootstrap.Modal.getInstance(document.getElementById('editChildModal')).hide();
            loadChildren();
        } else {
            showToast(result.error?.message || 'Update failed', 'danger');
        }
    } catch (error) {
        console.error('Update error:', error);
        showToast('Failed to update child', 'danger');
    }
}
</script>
