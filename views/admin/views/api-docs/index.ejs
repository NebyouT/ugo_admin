<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API Documentation - UGO Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root { --primary: #667eea; --secondary: #764ba2; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f8f9fa; margin-left: 260px; }
        .main-content { padding: 2rem; min-height: 100vh; }
        .page-header { background: white; border-radius: 1rem; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,.1); position: relative; }
        .notification-badge { position: absolute; top: 1rem; right: 1rem; background: #dc3545; color: white; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: .8rem; font-weight: 700; animation: pulse 2s infinite; cursor: pointer; }
        @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
        .section-header { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: white; padding: 1.5rem; border-radius: .5rem; margin-bottom: 1rem; }
        .section-header h2 { font-size: 1.5rem; font-weight: 600; margin: 0; }
        .ep { background: white; border-radius: .5rem; padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 2px 4px rgba(0,0,0,.08); border-left: 4px solid #dee2e6; position: relative; }
        .ep.public { border-left-color: #28a745; }
        .ep.protected { border-left-color: #ffc107; }
        .ep.has-unread { border-left-color: #dc3545; }
        .badge-method { display: inline-block; padding: .25rem .6rem; border-radius: .25rem; font-size: .7rem; font-weight: 700; text-transform: uppercase; color: white; margin-right: .5rem; }
        .badge-get { background: #28a745; }
        .badge-post { background: #007bff; }
        .badge-delete { background: #dc3545; }
        .badge-put { background: #ffc107; color: #333; }
        .badge-patch { background: #17a2b8; }
        .badge-auth { background: #ffc107; color: #333; font-size: .65rem; padding: .15rem .4rem; border-radius: .15rem; }
        .ep-path { font-family: 'Courier New', monospace; background: #f0f0f0; padding: .4rem .8rem; border-radius: .25rem; font-weight: 600; color: #d63384; display: inline-block; margin: .5rem 0; font-size: .9rem; }
        .json-block { background: #1e1e2e; color: #cdd6f4; border-radius: .5rem; padding: 1rem; font-family: 'Courier New', monospace; font-size: .8rem; overflow-x: auto; white-space: pre; margin: .75rem 0; }
        .resp-label { font-weight: 600; font-size: .85rem; margin-top: 1rem; margin-bottom: .25rem; }
        .resp-label.success { color: #28a745; }
        .resp-label.error { color: #dc3545; }
        .comment-section { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 2px solid #e9ecef; }
        .comment-box { background: #f8f9fa; border-radius: .5rem; padding: 1rem; margin-bottom: .75rem; position: relative; }
        .comment-box.unread { background: #fff3cd; border-left: 3px solid #ffc107; }
        .comment-header { display: flex; justify-content: between; align-items: center; margin-bottom: .5rem; }
        .comment-author { font-weight: 600; font-size: .85rem; color: var(--primary); }
        .comment-time { font-size: .75rem; color: #6c757d; margin-left: auto; }
        .comment-text { font-size: .9rem; color: #495057; margin-top: .5rem; }
        .issue-badge { font-size: .7rem; padding: .15rem .4rem; border-radius: .15rem; margin-left: .5rem; }
        .issue-bug { background: #dc3545; color: white; }
        .issue-question { background: #17a2b8; color: white; }
        .issue-suggestion { background: #28a745; color: white; }
        .issue-note { background: #6c757d; color: white; }
        .issue-error { background: #ffc107; color: #333; }
        .comment-form { margin-top: 1rem; }
        .unread-badge { position: absolute; top: 1rem; right: 1rem; background: #dc3545; color: white; font-size: .7rem; padding: .2rem .5rem; border-radius: .25rem; font-weight: 600; }
        .comment-actions { margin-top: .5rem; }
        .comment-actions button { font-size: .75rem; padding: .2rem .5rem; }
        @media (max-width: 768px) { body { margin-left: 0; } .main-content { padding: 1rem; } }
    </style>
</head>
<body>
    <%- include('../../components/sidebar') %>

    <main class="main-content">
        <div class="page-header">
            <h1 class="h2 mb-1">API Documentation</h1>
            <p class="text-muted mb-0">Dynamic API reference with developer comments</p>
            <div class="notification-badge" id="notificationBadge" style="display:none;" title="Unread comments">0</div>
        </div>

        <div id="apiContent">
            <div class="text-center py-5">
                <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
                <p class="mt-3 text-muted">Loading API documentation...</p>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    const API = '/api/docs';
    const headers = { 'Accept': 'application/json', 'Content-Type': 'application/json' };

    // Load API endpoints
    async function loadEndpoints() {
        try {
            const res = await fetch(`${API}/endpoints`, { headers, credentials: 'include' });
            const data = await res.json();
            
            if (!data.success) throw new Error(data.message);

            const grouped = data.data.grouped;
            let html = '';

            // Render each category
            for (const [category, endpoints] of Object.entries(grouped)) {
                html += `<div class="section-header"><h2>${category}</h2></div>`;
                
                endpoints.forEach(ep => {
                    const methodClass = `badge-${ep.method.toLowerCase()}`;
                    const authClass = ep.requiresAuth ? 'protected' : 'public';
                    const hasUnread = ep.unreadCommentsCount > 0;
                    
                    html += `
                    <div class="ep ${authClass} ${hasUnread ? 'has-unread' : ''}" id="ep-${ep._id}">
                        ${hasUnread ? `<span class="unread-badge">${ep.unreadCommentsCount} new</span>` : ''}
                        <h4>
                            <span class="badge-method ${methodClass}">${ep.method}</span>
                            ${ep.title}
                            ${ep.requiresAuth ? '<span class="badge-auth"><i class="fas fa-lock"></i> Auth</span>' : ''}
                        </h4>
                        <div class="ep-path">${ep.endpoint}</div>
                        <p>${ep.description}</p>`;
                    
                    if (ep.requestBody) {
                        html += `<p class="resp-label">Request Body:</p>
                        <div class="json-block">${typeof ep.requestBody === 'string' ? ep.requestBody : JSON.stringify(ep.requestBody, null, 2)}</div>`;
                    }
                    
                    if (ep.requestExample) {
                        html += `<p class="resp-label">Example Request:</p>
                        <div class="json-block">${ep.requestExample}</div>`;
                    }
                    
                    if (ep.responseSuccess) {
                        html += `<p class="resp-label success">Success Response:</p>
                        <div class="json-block">${typeof ep.responseSuccess === 'string' ? ep.responseSuccess : JSON.stringify(ep.responseSuccess, null, 2)}</div>`;
                    }
                    
                    if (ep.responseError) {
                        html += `<p class="resp-label error">Error Response:</p>
                        <div class="json-block">${typeof ep.responseError === 'string' ? ep.responseError : JSON.stringify(ep.responseError, null, 2)}</div>`;
                    }
                    
                    if (ep.notes) {
                        html += `<p class="mt-3"><strong>Note:</strong> ${ep.notes}</p>`;
                    }
                    
                    // Comment section
                    html += `
                    <div class="comment-section">
                        <h6><i class="fas fa-comments me-2"></i>Developer Comments</h6>
                        <div id="comments-${ep._id}"></div>
                        <div class="comment-form">
                            <textarea class="form-control form-control-sm mb-2" id="comment-text-${ep._id}" rows="2" placeholder="Report an issue or leave a note..."></textarea>
                            <div class="d-flex gap-2">
                                <select class="form-select form-select-sm" id="issue-type-${ep._id}" style="width:auto">
                                    <option value="note">Note</option>
                                    <option value="bug">Bug</option>
                                    <option value="error">Error</option>
                                    <option value="question">Question</option>
                                    <option value="suggestion">Suggestion</option>
                                </select>
                                <button class="btn btn-sm btn-primary" onclick="addComment('${ep._id}')"><i class="fas fa-paper-plane me-1"></i>Add Comment</button>
                            </div>
                        </div>
                    </div>
                    </div>`;
                });
            }

            document.getElementById('apiContent').innerHTML = html;
            
            // Load comments for each endpoint
            for (const [category, endpoints] of Object.entries(grouped)) {
                endpoints.forEach(ep => loadComments(ep._id));
            }
            
            // Load unread count
            loadUnreadCount();
        } catch (error) {
            console.error('Load endpoints error:', error);
            document.getElementById('apiContent').innerHTML = `
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>Failed to load API documentation: ${error.message}
                </div>`;
        }
    }

    // Load comments for an endpoint
    async function loadComments(endpointId) {
        try {
            const res = await fetch(`${API}/endpoints/${endpointId}/comments`, { headers, credentials: 'include' });
            const data = await res.json();
            
            if (!data.success) return;

            const comments = data.data.comments;
            const container = document.getElementById(`comments-${endpointId}`);
            
            if (!comments.length) {
                container.innerHTML = '<p class="text-muted small">No comments yet. Be the first to comment!</p>';
                return;
            }

            container.innerHTML = comments.map(c => {
                const date = new Date(c.createdAt).toLocaleString();
                const issueClass = `issue-${c.issueType}`;
                const unreadClass = c.isRead ? '' : 'unread';
                
                return `
                <div class="comment-box ${unreadClass}">
                    <div class="comment-header">
                        <span class="comment-author">${c.authorName}</span>
                        <span class="issue-badge ${issueClass}">${c.issueType}</span>
                        <span class="comment-time">${date}</span>
                    </div>
                    <div class="comment-text">${c.comment}</div>
                    ${!c.isRead ? `
                    <div class="comment-actions">
                        <button class="btn btn-sm btn-outline-success" onclick="markRead('${c._id}', '${endpointId}')"><i class="fas fa-check me-1"></i>Mark Read</button>
                        <button class="btn btn-sm btn-outline-primary" onclick="resolveComment('${c._id}', '${endpointId}')"><i class="fas fa-check-double me-1"></i>Resolve</button>
                    </div>` : ''}
                    ${c.status === 'resolved' ? '<span class="badge bg-success mt-2">Resolved</span>' : ''}
                </div>`;
            }).join('');
        } catch (error) {
            console.error('Load comments error:', error);
        }
    }

    // Add comment
    async function addComment(endpointId) {
        const text = document.getElementById(`comment-text-${endpointId}`).value.trim();
        const issueType = document.getElementById(`issue-type-${endpointId}`).value;
        
        if (!text) {
            alert('Please enter a comment');
            return;
        }

        try {
            const res = await fetch(`${API}/endpoints/${endpointId}/comments`, {
                method: 'POST',
                headers,
                credentials: 'include',
                body: JSON.stringify({ comment: text, issueType })
            });
            
            const data = await res.json();
            
            if (data.success) {
                document.getElementById(`comment-text-${endpointId}`).value = '';
                loadComments(endpointId);
                loadUnreadCount();
            } else {
                alert(data.message || 'Failed to add comment');
            }
        } catch (error) {
            console.error('Add comment error:', error);
            alert('Failed to add comment');
        }
    }

    // Mark comment as read
    async function markRead(commentId, endpointId) {
        try {
            const res = await fetch(`${API}/comments/${commentId}/read`, {
                method: 'PATCH',
                headers,
                credentials: 'include'
            });
            
            if (res.ok) {
                loadComments(endpointId);
                loadUnreadCount();
            }
        } catch (error) {
            console.error('Mark read error:', error);
        }
    }

    // Resolve comment
    async function resolveComment(commentId, endpointId) {
        try {
            const res = await fetch(`${API}/comments/${commentId}/resolve`, {
                method: 'PATCH',
                headers,
                credentials: 'include'
            });
            
            if (res.ok) {
                loadComments(endpointId);
                loadUnreadCount();
            }
        } catch (error) {
            console.error('Resolve error:', error);
        }
    }

    // Load unread count
    async function loadUnreadCount() {
        try {
            const res = await fetch(`${API}/comments/unread-count`, { headers, credentials: 'include' });
            const data = await res.json();
            
            if (data.success) {
                const count = data.data.count;
                const badge = document.getElementById('notificationBadge');
                
                if (count > 0) {
                    badge.textContent = count;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
            }
        } catch (error) {
            console.error('Load unread count error:', error);
        }
    }

    // Auto-refresh unread count every 30 seconds
    setInterval(loadUnreadCount, 30000);

    // Init
    loadEndpoints();
    </script>
</body>
</html>
