<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --card-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
            margin-left: 250px;
        }

        .main-content {
            padding: 2rem;
            min-height: 100vh;
        }

        .page-header {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--card-shadow);
        }

        .auth-card {
            background: white;
            border-radius: 1rem;
            padding: 2rem;
            box-shadow: var(--card-shadow);
            margin-bottom: 2rem;
        }

        .stats-card {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: var(--card-shadow);
            text-align: center;
        }

        .stats-number {
            font-size: 2rem;
            font-weight: bold;
            color: var(--primary-color);
        }

        .status-badge {
            font-size: 0.8rem;
            padding: 0.25rem 0.5rem;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .otp-code {
            font-family: 'Courier New', monospace;
            font-size: 1.2rem;
            font-weight: bold;
            letter-spacing: 0.2rem;
            background: #f8f9fa;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            border: 2px dashed #dee2e6;
        }

        .device-info {
            font-size: 0.8rem;
            color: #6c757d;
        }

        .filter-section {
            background: white;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: var(--card-shadow);
        }

        .timeline {
            position: relative;
            padding-left: 2rem;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #dee2e6;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 2rem;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.5rem;
            top: 0.5rem;
            width: 1rem;
            height: 1rem;
            border-radius: 50%;
            background: var(--primary-color);
            border: 2px solid white;
        }

        .timeline-item.success::before {
            background: #28a745;
        }

        .timeline-item.warning::before {
            background: #ffc107;
        }

        .timeline-item.danger::before {
            background: #dc3545;
        }

        @media (max-width: 768px) {
            body {
                margin-left: 0;
            }
            
            .main-content {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle" onclick="toggleSidebar()">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar Component -->
    <%- include('../../components/sidebar', { user: user, currentPath: currentPath }) %>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h2 mb-0">Authentication Management</h1>
                    <p class="text-muted mb-0">Monitor and manage user authentication activities</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary me-2" onclick="refreshData()">
                        <i class="fas fa-sync-alt me-2"></i>Refresh
                    </button>
                    <button class="btn btn-primary" onclick="showManualOTPModal()">
                        <i class="fas fa-key me-2"></i>Generate OTP
                    </button>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="totalRegistrations">-</div>
                    <div class="text-muted">Total Registrations</div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="pendingVerifications">-</div>
                    <div class="text-muted">Pending Verifications</div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="activeSessions">-</div>
                    <div class="text-muted">Active Sessions</div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="stats-card">
                    <div class="stats-number" id="todayLogins">-</div>
                    <div class="text-muted">Today's Logins</div>
                </div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="statusFilter" class="form-label">Status</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">All Status</option>
                        <option value="pending">Pending Verification</option>
                        <option value="verified">Verified</option>
                        <option value="suspended">Suspended</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="userTypeFilter" class="form-label">User Type</label>
                    <select class="form-select" id="userTypeFilter">
                        <option value="">All Types</option>
                        <option value="parent">Parent</option>
                        <option value="driver">Driver</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="dateFilter" class="form-label">Date Range</label>
                    <select class="form-select" id="dateFilter">
                        <option value="today">Today</option>
                        <option value="week">This Week</option>
                        <option value="month">This Month</option>
                        <option value="all">All Time</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-grid">
                        <button class="btn btn-outline-primary" onclick="applyFilters()">
                            <i class="fas fa-filter me-2"></i>Apply Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Authentication Activities -->
        <div class="auth-card">
            <h4 class="mb-4">Recent Authentication Activities</h4>
            <div class="timeline" id="authTimeline">
                <!-- Timeline items will be loaded here -->
            </div>
        </div>

        <!-- Pending Verifications -->
        <div class="auth-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Pending Verifications</h4>
                <span class="badge bg-warning" id="pendingCount">0</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Type</th>
                            <th>Contact</th>
                            <th>OTP</th>
                            <th>Expires</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="pendingVerificationsTable">
                        <!-- Pending verifications will be loaded here -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Active Sessions -->
        <div class="auth-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Active Sessions</h4>
                <span class="badge bg-success" id="activeCount">0</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Device</th>
                            <th>IP Address</th>
                            <th>Login Time</th>
                            <th>Last Activity</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="activeSessionsTable">
                        <!-- Active sessions will be loaded here -->
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Manual OTP Modal -->
    <div class="modal fade" id="manualOTPModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Generate Manual OTP</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="manualOTPForm">
                        <div class="mb-3">
                            <label for="phone" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="phone" name="phone" placeholder="0912345678" required>
                        </div>
                        <div class="mb-3">
                            <label for="purpose" class="form-label">Purpose</label>
                            <select class="form-select" id="purpose" name="purpose" required>
                                <option value="registration">Registration</option>
                                <option value="password_reset">Password Reset</option>
                                <option value="login_verification">Login Verification</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="expiryMinutes" class="form-label">Expiry (minutes)</label>
                            <input type="number" class="form-control" id="expiryMinutes" name="expiryMinutes" value="5" min="1" max="60" required>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="generateManualOTP()">Generate OTP</button>
                </div>
            </div>
        </div>
    </div>

    <!-- OTP Result Modal -->
    <div class="modal fade" id="otpResultModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">OTP Generated Successfully</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <div class="otp-code mb-3" id="generatedOTP">-</div>
                    <p class="text-muted mb-3">This OTP will expire in <span id="otpExpiry">5</span> minutes</p>
                    <div class="mb-3">
                        <small class="text-muted">Phone: <span id="otpPhone">-</span></small>
                    </div>
                    <button class="btn btn-outline-primary" onclick="copyOTP()">
                        <i class="fas fa-copy me-2"></i>Copy OTP
                    </button>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Container -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1050;">
        <div id="alertContainer"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentUser = null;
        let authData = {
            registrations: [],
            pendingVerifications: [],
            activeSessions: [],
            timeline: []
        };

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            initializePage();
        });

        // Check authentication and load data
        async function initializePage() {
            try {
                await checkAuthStatus();
                await loadAuthData();
                setupEventListeners();
            } catch (error) {
                console.error('Failed to initialize page:', error);
                if (error.message.includes('Authentication')) {
                    window.location.href = '/admin/login';
                }
            }
        }

        // Check authentication status
        async function checkAuthStatus() {
            try {
                const response = await fetch('/admin/auth/check');
                const result = await response.json();
                
                if (!result.success || !result.data.user) {
                    throw new Error('Authentication failed');
                }
                
                currentUser = result.data.user;
            } catch (error) {
                console.error('Auth check failed:', error);
                window.location.href = '/admin/login';
                throw error;
            }
        }

        // Load authentication data
        async function loadAuthData() {
            try {
                // Load real data from API
                const [statsResponse, pendingResponse, sessionsResponse, timelineResponse] = await Promise.all([
                    fetch('/api/admin/auth/stats'),
                    fetch('/api/admin/auth/pending-verifications'),
                    fetch('/api/admin/auth/active-sessions'),
                    fetch('/api/admin/auth/timeline')
                ]);

                const [stats, pending, sessions, timeline] = await Promise.all([
                    statsResponse.json(),
                    pendingResponse.json(),
                    sessionsResponse.json(),
                    timelineResponse.json()
                ]);

                if (stats.success && pending.success && sessions.success && timeline.success) {
                    authData = {
                        registrations: [],
                        pendingVerifications: pending.data.users || [],
                        activeSessions: sessions.data.users || [],
                        timeline: timeline.data.timeline || []
                    };
                    
                    renderStats();
                    renderTimeline();
                    renderPendingVerifications();
                    renderActiveSessions();
                } else {
                    throw new Error('Failed to load authentication data');
                }
            } catch (error) {
                console.error('Load auth data error:', error);
                // Fallback to demo data
                authData = getDemoAuthData();
                renderStats();
                renderTimeline();
                renderPendingVerifications();
                renderActiveSessions();
                showAlert('Using demo data. API connection failed.', 'warning');
            }
        }

        // Get demo authentication data
        function getDemoAuthData() {
            return {
                registrations: [
                    {
                        id: 'reg_001',
                        user: { firstName: 'John', lastName: 'Doe', phone: '0911234567', userType: 'parent' },
                        status: 'pending',
                        createdAt: new Date(Date.now() - 2 * 60 * 60 * 1000),
                        deviceInfo: { device_type: 'android', device_id: 'abc123' }
                    },
                    {
                        id: 'reg_002',
                        user: { firstName: 'Jane', lastName: 'Smith', phone: '0912345678', userType: 'driver' },
                        status: 'verified',
                        createdAt: new Date(Date.now() - 4 * 60 * 60 * 1000),
                        deviceInfo: { device_type: 'ios', device_id: 'xyz789' }
                    }
                ],
                pendingVerifications: [
                    {
                        id: 'pending_001',
                        user: { firstName: 'John', lastName: 'Doe', phone: '0911234567', userType: 'parent' },
                        otp: '123456',
                        otpExpiresAt: new Date(Date.now() + 3 * 60 * 1000),
                        purpose: 'registration',
                        createdAt: new Date(Date.now() - 2 * 60 * 60 * 1000)
                    },
                    {
                        id: 'pending_002',
                        user: { firstName: 'Mike', lastName: 'Wilson', phone: '0922345678', userType: 'driver' },
                        otp: '789012',
                        otpExpiresAt: new Date(Date.now() + 4 * 60 * 1000),
                        purpose: 'password_reset',
                        createdAt: new Date(Date.now() - 1 * 60 * 60 * 1000)
                    }
                ],
                activeSessions: [
                    {
                        id: 'session_001',
                        user: { firstName: 'Jane', lastName: 'Smith', phone: '0912345678' },
                        deviceInfo: { device_type: 'web', device_id: 'web123' },
                        ipAddress: '192.168.1.100',
                        loginTime: new Date(Date.now() - 30 * 60 * 1000),
                        lastActivity: new Date(Date.now() - 5 * 60 * 1000)
                    },
                    {
                        id: 'session_002',
                        user: { firstName: 'Sarah', lastName: 'Brown', phone: '0913456789' },
                        deviceInfo: { device_type: 'android', device_id: 'android456' },
                        ipAddress: '192.168.1.101',
                        loginTime: new Date(Date.now() - 2 * 60 * 60 * 1000),
                        lastActivity: new Date(Date.now() - 15 * 60 * 1000)
                    }
                ],
                timeline: [
                    {
                        id: 'timeline_001',
                        type: 'registration',
                        user: { firstName: 'John', lastName: 'Doe', phone: '0911234567' },
                        action: 'New user registration',
                        status: 'pending',
                        timestamp: new Date(Date.now() - 2 * 60 * 60 * 1000),
                        details: 'User registered as parent, OTP sent to phone'
                    },
                    {
                        id: 'timeline_002',
                        type: 'login',
                        user: { firstName: 'Jane', lastName: 'Smith', phone: '0912345678' },
                        action: 'User login',
                        status: 'success',
                        timestamp: new Date(Date.now() - 30 * 60 * 1000),
                        details: 'Driver logged in from web browser'
                    },
                    {
                        id: 'timeline_003',
                        type: 'verification',
                        user: { firstName: 'Mike', lastName: 'Wilson', phone: '0922345678' },
                        action: 'Password reset requested',
                        status: 'warning',
                        timestamp: new Date(Date.now() - 1 * 60 * 60 * 1000),
                        details: 'Driver requested password reset, OTP generated'
                    }
                ]
            };
        }

        // Render statistics
        function renderStats() {
            document.getElementById('totalRegistrations').textContent = authData.registrations.length;
            document.getElementById('pendingVerifications').textContent = authData.pendingVerifications.length;
            document.getElementById('activeSessions').textContent = authData.activeSessions.length;
            document.getElementById('todayLogins').textContent = authData.timeline.filter(item => item.type === 'login').length;
        }

        // Render timeline
        function renderTimeline() {
            const timeline = document.getElementById('authTimeline');
            timeline.innerHTML = '';

            if (authData.timeline.length === 0) {
                timeline.innerHTML = '<div class="text-center text-muted py-4">No authentication activities found</div>';
                return;
            }

            authData.timeline.forEach(item => {
                const timelineItem = document.createElement('div');
                timelineItem.className = `timeline-item ${item.status}`;
                
                const statusIcon = {
                    'success': 'fa-check-circle',
                    'warning': 'fa-exclamation-triangle',
                    'pending': 'fa-clock',
                    'danger': 'fa-times-circle'
                }[item.status] || 'fa-info-circle';

                timelineItem.innerHTML = `
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">${item.action}</div>
                            <div class="text-muted small">
                                <i class="fas fa-user me-1"></i>${item.user.firstName} ${item.user.lastName} (${item.user.phone})
                            </div>
                            <div class="text-muted small">${item.details}</div>
                        </div>
                        <div class="text-end">
                            <i class="fas ${statusIcon} text-${item.status === 'success' ? 'success' : item.status === 'warning' ? 'warning' : item.status === 'danger' ? 'danger' : 'primary'}"></i>
                            <div class="small text-muted">${formatTime(item.timestamp)}</div>
                        </div>
                    </div>
                `;
                
                timeline.appendChild(timelineItem);
            });
        }

        // Render pending verifications
        function renderPendingVerifications() {
            const tbody = document.getElementById('pendingVerificationsTable');
            tbody.innerHTML = '';

            document.getElementById('pendingCount').textContent = authData.pendingVerifications.length;

            if (authData.pendingVerifications.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No pending verifications
                        </td>
                    </tr>
                `;
                return;
            }

            authData.pendingVerifications.forEach(verification => {
                const row = document.createElement('tr');
                const timeLeft = Math.max(0, Math.floor((verification.otpExpiresAt - new Date()) / 60000));
                
                row.innerHTML = `
                    <td>
                        <div class="d-flex align-items-center">
                            <img src="https://ui-avatars.com/api/?name=${verification.user.firstName}+${verification.user.lastName}&background=random" 
                                 alt="${verification.user.firstName} ${verification.user.lastName}" class="user-avatar me-3">
                            <div>
                                <div class="fw-semibold">${verification.user.firstName} ${verification.user.lastName}</div>
                                <div class="text-muted small">${verification.user.phone}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-info">${verification.user.userType}</span>
                    </td>
                    <td>${verification.user.phone}</td>
                    <td>
                        <div class="otp-code">${verification.otp}</div>
                    </td>
                    <td>
                        <div class="text-muted small">
                            <div>${formatTime(verification.otpExpiresAt)}</div>
                            <div class="${timeLeft < 2 ? 'text-danger' : 'text-warning'}">${timeLeft} min left</div>
                        </div>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-outline-success" onclick="approveVerification('${verification.id}')">
                                <i class="fas fa-check"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="rejectVerification('${verification.id}')">
                                <i class="fas fa-times"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary" onclick="resendOTP('${verification.id}')">
                                <i class="fas fa-redo"></i>
                            </button>
                        </div>
                    </td>
                `;
                
                tbody.appendChild(row);
            });
        }

        // Render active sessions
        function renderActiveSessions() {
            const tbody = document.getElementById('activeSessionsTable');
            tbody.innerHTML = '';

            document.getElementById('activeCount').textContent = authData.activeSessions.length;

            if (authData.activeSessions.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No active sessions
                        </td>
                    </tr>
                `;
                return;
            }

            authData.activeSessions.forEach(session => {
                const row = document.createElement('tr');
                
                row.innerHTML = `
                    <td>
                        <div class="d-flex align-items-center">
                            <img src="https://ui-avatars.com/api/?name=${session.user.firstName}+${session.user.lastName}&background=random" 
                                 alt="${session.user.firstName} ${session.user.lastName}" class="user-avatar me-3">
                            <div>
                                <div class="fw-semibold">${session.user.firstName} ${session.user.lastName}</div>
                                <div class="text-muted small">${session.user.phone}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="device-info">
                            <div><i class="fas fa-${session.deviceInfo.device_type === 'web' ? 'desktop' : 'mobile'} me-1"></i>${session.deviceInfo.device_type}</div>
                            <div class="text-muted">${session.deviceInfo.device_id}</div>
                        </div>
                    </td>
                    <td>${session.ipAddress}</td>
                    <td>
                        <div class="text-muted small">
                            <div>${formatTime(session.loginTime)}</div>
                        </div>
                    </td>
                    <td>
                        <div class="text-muted small">
                            <div>${formatTime(session.lastActivity)}</div>
                        </div>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-outline-warning" onclick="terminateSession('${session.id}')">
                                <i class="fas fa-sign-out-alt"></i>
                            </button>
                        </div>
                    </td>
                `;
                
                tbody.appendChild(row);
            });
        }

        // Format time
        function formatTime(date) {
            const now = new Date();
            const diff = now - date;
            const minutes = Math.floor(diff / 60000);
            const hours = Math.floor(diff / 3600000);
            const days = Math.floor(diff / 86400000);

            if (minutes < 1) return 'Just now';
            if (minutes < 60) return `${minutes} min ago`;
            if (hours < 24) return `${hours} hour${hours > 1 ? 's' : ''} ago`;
            return `${days} day${days > 1 ? 's' : ''} ago`;
        }

        // Setup event listeners
        function setupEventListeners() {
            // Filter listeners
            document.getElementById('statusFilter').addEventListener('change', applyFilters);
            document.getElementById('userTypeFilter').addEventListener('change', applyFilters);
            document.getElementById('dateFilter').addEventListener('change', applyFilters);
        }

        // Apply filters
        function applyFilters() {
            const status = document.getElementById('statusFilter').value;
            const userType = document.getElementById('userTypeFilter').value;
            const dateRange = document.getElementById('dateFilter').value;

            // Filter logic would go here
            console.log('Applying filters:', { status, userType, dateRange });
            
            // For now, just refresh the data
            loadAuthData();
            showAlert('Filters applied', 'info');
        }

        // Refresh data
        async function refreshData() {
            await loadAuthData();
            showAlert('Data refreshed successfully', 'success');
        }

        // Show manual OTP modal
        function showManualOTPModal() {
            const modal = new bootstrap.Modal(document.getElementById('manualOTPModal'));
            modal.show();
        }

        // Generate manual OTP
        async function generateManualOTP() {
            const form = document.getElementById('manualOTPForm');
            const formData = new FormData(form);
            
            const phone = formData.get('phone');
            const purpose = formData.get('purpose');
            const expiryMinutes = formData.get('expiryMinutes');

            try {
                const response = await fetch('/api/admin/auth/generate-otp', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        phone,
                        purpose,
                        expiryMinutes: parseInt(expiryMinutes)
                    })
                });

                const result = await response.json();

                if (result.success) {
                    // Show result modal
                    document.getElementById('generatedOTP').textContent = result.data.otp;
                    document.getElementById('otpPhone').textContent = result.data.phone;
                    document.getElementById('otpExpiry').textContent = expiryMinutes;
                    
                    // Close manual OTP modal and show result
                    bootstrap.Modal.getInstance(document.getElementById('manualOTPModal')).hide();
                    
                    const resultModal = new bootstrap.Modal(document.getElementById('otpResultModal'));
                    resultModal.show();
                    
                    // Reset form
                    form.reset();
                    
                    showAlert('OTP generated successfully', 'success');
                } else {
                    showAlert(result.message || 'Failed to generate OTP', 'danger');
                }
            } catch (error) {
                console.error('Generate OTP error:', error);
                showAlert('Failed to generate OTP', 'danger');
            }
        }

        // Copy OTP to clipboard
        function copyOTP() {
            const otp = document.getElementById('generatedOTP').textContent;
            navigator.clipboard.writeText(otp).then(() => {
                showAlert('OTP copied to clipboard', 'success');
            }).catch(err => {
                console.error('Failed to copy OTP:', err);
                showAlert('Failed to copy OTP', 'danger');
            });
        }

        // Approve verification
        async function approveVerification(id) {
            if (confirm('Are you sure you want to approve this verification?')) {
                try {
                    const response = await fetch(`/api/admin/auth/verify/${id}/approve`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    });

                    const result = await response.json();

                    if (result.success) {
                        // Remove from pending verifications
                        authData.pendingVerifications = authData.pendingVerifications.filter(v => v.id !== id);
                        renderPendingVerifications();
                        renderStats();
                        showAlert('Verification approved successfully', 'success');
                    } else {
                        showAlert(result.message || 'Failed to approve verification', 'danger');
                    }
                } catch (error) {
                    console.error('Approve verification error:', error);
                    showAlert('Failed to approve verification', 'danger');
                }
            }
        }

        // Reject verification
        async function rejectVerification(id) {
            if (confirm('Are you sure you want to reject this verification?')) {
                try {
                    const response = await fetch(`/api/admin/auth/verify/${id}/reject`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    });

                    const result = await response.json();

                    if (result.success) {
                        // Remove from pending verifications
                        authData.pendingVerifications = authData.pendingVerifications.filter(v => v.id !== id);
                        renderPendingVerifications();
                        renderStats();
                        showAlert('Verification rejected', 'warning');
                    } else {
                        showAlert(result.message || 'Failed to reject verification', 'danger');
                    }
                } catch (error) {
                    console.error('Reject verification error:', error);
                    showAlert('Failed to reject verification', 'danger');
                }
            }
        }

        // Resend OTP
        async function resendOTP(id) {
            try {
                const response = await fetch(`/api/admin/auth/verify/${id}/resend-otp`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });

                const result = await response.json();

                if (result.success) {
                    // Update the verification with new OTP
                    const verification = authData.pendingVerifications.find(v => v.id === id);
                    if (verification) {
                        verification.otp = result.data.otp;
                        verification.otpExpiresAt = new Date(result.data.expiresAt);
                    }
                    
                    renderPendingVerifications();
                    showAlert('OTP resent successfully', 'success');
                } else {
                    showAlert(result.message || 'Failed to resend OTP', 'danger');
                }
            } catch (error) {
                console.error('Resend OTP error:', error);
                showAlert('Failed to resend OTP', 'danger');
            }
        }

        // Terminate session
        async function terminateSession(id) {
            if (confirm('Are you sure you want to terminate this session?')) {
                try {
                    const response = await fetch(`/api/admin/auth/session/${id}/terminate`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    });

                    const result = await response.json();

                    if (result.success) {
                        authData.activeSessions = authData.activeSessions.filter(s => s.id !== id);
                        renderActiveSessions();
                        renderStats();
                        showAlert('Session terminated successfully', 'warning');
                    } else {
                        showAlert(result.message || 'Failed to terminate session', 'danger');
                    }
                } catch (error) {
                    console.error('Terminate session error:', error);
                    showAlert('Failed to terminate session', 'danger');
                }
            }
        }

        // Show alert message
        function showAlert(message, type = 'info') {
            const alertContainer = document.getElementById('alertContainer');
            const alertId = 'alert-' + Date.now();
            
            const alertHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert" id="${alertId}">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'danger' ? 'exclamation-triangle' : 'info-circle'} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            
            alertContainer.insertAdjacentHTML('beforeend', alertHTML);
            
            // Auto-dismiss after 5 seconds
            setTimeout(() => {
                const alert = document.getElementById(alertId);
                if (alert) {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }
            }, 5000);
        }

        // Periodic auth check (every 5 minutes)
        setInterval(checkAuthStatus, 5 * 60 * 1000);
    </script>
</body>
</html>
