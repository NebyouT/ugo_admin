<!-- UGO Banner Background Placeholder -->
<svg width="1920" height="800" viewBox="0 0 1920 800" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="1920" height="800" fill="url(#bannerGradient)"/>
  <defs>
    <linearGradient id="bannerGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:0.8"/>
      <stop offset="50%" style="stop-color:#764ba2;stop-opacity:0.6"/>
      <stop offset="100%" style="stop-color:#f093fb;stop-opacity:0.4"/>
    </linearGradient>
  </defs>
  <circle cx="1600" cy="200" r="150" fill="white" opacity="0.1"/>
  <circle cx="300" cy="600" r="200" fill="white" opacity="0.05"/>
  <circle cx="1000" cy="400" r="100" fill="white" opacity="0.08"/>
</svg>
